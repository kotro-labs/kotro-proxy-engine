{
  "name": "kortolabs-proxy-engine",
  "displayName": "KortoLabs Proxy Engine",
  "description": "Transparent IDE sidecar for the Korto semantic caching LLM proxy.",
  "version": "0.1.0",
  "publisher": "kortolabs",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ramairwing/kotro-proxy-engine.git",
    "directory": "distributions/vscode-extension"
  },
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": ["Other"],
  "activationEvents": ["onStartupFinished"],
  "main": "./out/extension.js",
  "contributes": {
    "configuration": {
      "title": "KortoLabs Proxy",
      "properties": {
        "kortolabs.listenAddr": {
          "type": "string",
          "default": ":8080",
          "description": "Proxy bind address (KORTO_LISTEN_ADDR)."
        },
        "kortolabs.upstreamUrl": {
          "type": "string",
          "default": "https://api.openai.com",
          "description": "Upstream provider base URL (KORTO_UPSTREAM_URL)."
        },
        "kortolabs.cacheDb": {
          "type": "string",
          "default": "",
          "description": "Cache database path. Empty uses extension global storage."
        },
        "kortolabs.enableCache": {
          "type": "boolean",
          "default": true
        },
        "kortolabs.enableRedaction": {
          "type": "boolean",
          "default": true
        },
        "kortolabs.enableCompression": {
          "type": "boolean",
          "default": true
        }
      }
    }
  },
  "scripts": {
    "compile": "tsc -p .",
    "watch": "tsc -watch -p .",
    "vscode:prepublish": "npm run compile",
    "package": "vsce package --no-dependencies"
  },
  "devDependencies": {
    "@types/node": "^20.14.0",
    "@types/vscode": "^1.85.0",
    "@vscode/vsce": "^3.2.0",
    "typescript": "^5.5.0"
  }
}
